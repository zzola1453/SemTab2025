ANTHROPIC_API_KEY=your_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Elasticsearch
ES_HOST=http://localhost:9200
ES_INDEX=wikidata_entities

# Dataset paths
TABLES_DIR=.data/mammotab_semtab_2025/tables
TARGET_FILE=.data/mammotab_semtab_2025/target_mammotab_2025.csv

# KG dump path (set after download)
WIKIDATA_DUMP_PATH=/path/to/wikidata-20240720-all.json.gz

# Pipeline settings
RETRIEVAL_BACKEND=wikidata_api  # wikidata_api | elasticsearch
MAX_CANDIDATES=10
USE_DEBATE=true
USE_VERIFICATION=false
BATCH_SIZE=5
